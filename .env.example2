# =============================================================================
# OpenGame — Cloudflare Workers AI configuration (Kimi K2.6 + Flux 2 Klein 9B)
# =============================================================================
#
# Copy this file to `.env` and replace every <PLACEHOLDER> value below with
# your real credentials. Two values to fill in:
#
#   1. <CF_ACCOUNT_ID>   — your Cloudflare account ID (32-char hex). Find it
#                          in the Cloudflare dashboard URL or under
#                          Workers & Pages > Overview > Account ID.
#   2. <CF_API_TOKEN>    — a Cloudflare API token with the "Workers AI" scope.
#                          Create at https://dash.cloudflare.com/profile/api-tokens
#                          (use the "Workers AI" template).
#
# Both endpoints are reached with the SAME api token. Note the URL path
# difference: chat uses `/ai/v1` (OpenAI-shape), image uses `/ai/run` (native).
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Main agent LLM — Cloudflare Workers AI / Moonshot Kimi K2.6
# -----------------------------------------------------------------------------
# 1T params, 262k context window, multi-turn tool calling, vision, structured
# outputs. Auto-detected by base-URL pattern; the agent runtime applies the
# Kimi quirks (max_tokens→max_completion_tokens, chat_template_kwargs.thinking,
# tool-call hardening) automatically.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<CF_ACCOUNT_ID>/ai/v1
OPENAI_MODEL=@cf/moonshotai/kimi-k2.6


# -----------------------------------------------------------------------------
# 2. Image generation — Cloudflare Workers AI / Black Forest Labs Flux 2 Klein 9B
# -----------------------------------------------------------------------------
# Used for sprites, backgrounds, tilesets, and animation base frames. The
# `cloudflare` provider sends multipart/form-data and accepts any @cf/*
# image model — change OPENGAME_IMAGE_MODEL to swap models.

OPENGAME_IMAGE_PROVIDER=cloudflare
OPENGAME_IMAGE_API_KEY=
OPENGAME_IMAGE_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<CF_ACCOUNT_ID>/ai/run
OPENGAME_IMAGE_MODEL=@cf/black-forest-labs/flux-2-klein-9b


# -----------------------------------------------------------------------------
# 3. Reasoning model (used by classify-game-type, generate-gdd, audio ABC tool)
# -----------------------------------------------------------------------------
# Cloudflare's Kimi K2.6 is OpenAI-compatible, so you can reuse it as the
# reasoning model via the `openai-compat` provider type. The reasoning service
# is a separate code path from the main agent loop — it does NOT inherit the
# Cloudflare-specific quirks, so plain OpenAI-compat works here.

OPENGAME_REASONING_PROVIDER=openai-compat
OPENGAME_REASONING_API_KEY=
OPENGAME_REASONING_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<CF_ACCOUNT_ID>/ai/v1
OPENGAME_REASONING_MODEL=@cf/moonshotai/kimi-k2.6


# -----------------------------------------------------------------------------
# 4. Video generation — NOT supported on Cloudflare Workers AI today
# -----------------------------------------------------------------------------
# Cloudflare doesn't host T2V/I2V models in the OpenGame shape. Leave UNSET to
# disable animations (asset generation will fall back to static sprites), or
# point at a different provider (tongyi/doubao):
#
# OPENGAME_VIDEO_PROVIDER=doubao
# OPENGAME_VIDEO_API_KEY=...
# OPENGAME_VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENGAME_VIDEO_MODEL=doubao-seedance-1-0-pro-250528


# -----------------------------------------------------------------------------
# 5. Audio generation — reuse Kimi K2.6 for ABC notation, or leave UNSET
# -----------------------------------------------------------------------------
# Audio is optional; the procedural fallback works without any LLM. To use
# Kimi K2.6 to author ABC notation, point the audio modality at the same
# OpenAI-compat endpoint:
#
# OPENGAME_AUDIO_PROVIDER=openai-compat
# OPENGAME_AUDIO_API_KEY=
# OPENGAME_AUDIO_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<CF_ACCOUNT_ID>/ai/v1
# OPENGAME_AUDIO_MODEL=@cf/moonshotai/kimi-k2.6


# -----------------------------------------------------------------------------
# 6. Local helpers (optional)
# -----------------------------------------------------------------------------
# PYTHON_PATH=/usr/local/bin/python3
# BACKGROUND_REMOVAL_BACKEND=imgly
